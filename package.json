{
  "name": "mern-api",
  "version": "1.0.0",
  "description": "Express API (login, cards) backed by MongoDB",
  "main": "server.js",
  "scripts": {
    "test": "NODE_ENV=test jest --runInBand --forceExit",
    "test:integration": "NODE_ENV=test jest --runInBand --forceExit --testPathPattern=integration",
    "start": "nodemon server.js",
    "seed": "node scripts/seed-eval-challenge.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@johnnymorganz/stylua": "^2.4.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.4",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "nodemailer": "^8.0.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.3.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "testTimeout": 60000
  }
}
